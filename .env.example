# ===========================================
# Oracle DBA 학습 게임 환경 변수
# ===========================================
# 헌법 제8-2조: 모든 환경별 값은 .env에 정의. 코드에 하드코딩 금지.
# 사용법: cp .env.example .env 후 값 채우기

# --- 환경 ---
NODE_ENV=development

# --- 포트 ---
WEB_PORT=3000
API_PORT=3001
POSTGRES_PORT=5432
REDIS_PORT=6379

# --- PostgreSQL ---
POSTGRES_USER=oracle_game
POSTGRES_PASSWORD=changeme
POSTGRES_DB=oracle_game

# --- 인증 ---
# 32바이트 이상 랜덤 문자열 사용 (예: openssl rand -base64 32)
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- LLM 공급자 (AI 문제 생성) ---
# anthropic | openai
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-opus-4-6

# --- 노션 연동 (선택) ---
NOTION_API_TOKEN=
NOTION_DATABASE_ID=

# --- 프론트엔드 ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# --- 시드 (개발/CI 전용) ---
# true면 부트 시 사전 생성 문제 풀(1주차 sql-basics)을 자동 INSERT
# 멱등 (이미 데이터가 있으면 skip)
# 프로덕션에서는 반드시 false 후 마이그레이션으로 관리
SEED_ON_BOOT=false
